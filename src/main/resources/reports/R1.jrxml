<jasperReport name="R1" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="5d965c4a-dc3a-4d22-9377-38b37f905849">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter (2)"/>
    <parameter name="FORKLIFT_IMAGE" class="java.io.InputStream"/>
	<query language="SQL"><![CDATA[SELECT
    w.name AS warehouse_name,
    w.location,
    w.capacity,
    p.name AS product_name,
    p.unitPrice,
    i.quantity,
    (i.quantity * p.unitPrice) AS total_value,
     SUM(p.volume * i.quantity) OVER (PARTITION BY w.id) AS occupied_capacity,
    i.lastUpdated
FROM inventory i
JOIN warehouse w ON i.warehouseId = w.id
JOIN product p ON i.productId = p.id
ORDER BY w.name, p.name]]></query>
