<jasperReport name="R3" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="64359ac9-0d5f-4d57-8baa-67ba917b0e3d">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="418"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="570"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter (2)"/>
    <parameter name="FORKLIFT_IMAGE" class="java.io.InputStream"/>
	<parameter name="DocumentNumber" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT warehouse.name AS warehouse_name,
	warehouse.location AS warehouse_location,
	warehouse.capacity AS warehouse_capacity,
	receipt.receiptdate AS receipt_date,
	receipt.documentnumber AS document_number,
	receipt.notes AS receipt_notes,
	receipt.isprocessed AS receipt_isprocessed,
	receiptitem.quantity AS receiptitem_quantity,
	receiptitem.isprocessed AS receiptitem_isprocessed,
	product.name AS product_name,
	product.unitprice AS product_unitprice,
	receiptitem.quantity * product.unitprice AS total_price,
	SUM(product.volume * receiptitem.quantity) OVER (PARTITION BY warehouse.id) AS occupied_capacity
FROM receiptitem
	INNER JOIN receipt ON 
	 receiptitem.receiptid = receipt.id 
	INNER JOIN warehouse ON 
	 receipt.warehouseid = warehouse.id 
	INNER JOIN product ON 
	 receiptitem.productid = product.id
	 WHERE receipt.documentnumber = $P{DocumentNumber}
	 ORDER BY product.name
	 ]]></query>
